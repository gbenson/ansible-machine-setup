[user]
	name = Gary Benson
	email = {{ git_commit_email | default("gary@gbenson.net") }}
[alias]
	ci = commit
	co = checkout
	di = diff
	st = status
	stat = status
	br = branch
[log]
	abbrevCommit = true
[push]
	default = matching
[init]
	defaultBranch = main
[pull]
	ff = only
[fetch]
	prune = true

